# Supabase project settings (Project Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Site URL used for sitemap/OG generation — set to your production domain when deploying
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email notifications for new contact submissions (optional — via https://resend.com).
# Leave RESEND_API_KEY blank to disable; submissions still save to the database.
RESEND_API_KEY=
# From address — must be a Resend-verified domain in production.
# The default onboarding@resend.dev works for testing once you have an API key.
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
# Where new-inquiry emails are sent. Defaults to the site contact email if blank.
CONTACT_NOTIFY_EMAIL=
